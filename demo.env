# CyberSOC Alpha — Environment Configuration
# Copy this to .env and fill in your values.
# The server loads these automatically if you use: node -r dotenv/register server.js
# Or just export them in your shell before running npm run dev.

# ── MaxMind GeoLite2 ──────────────────────────
# License key from: https://www.maxmind.com/en/accounts/current/license-key
MAXMIND_LICENSE_KEY=***HEREYOURKEY***

# ── Server ────────────────────────────────────
PORT=5021
SYSLOG_PORT=5514
DEMO_MODE=true
HEALTHCHECK_URL=http://localhost:5021/api/lockdown

# ── SOC Hub Location (shown on map and footer) ──
# Latitude and longitude of your SOC server location.
SERVER_LAT=46.740661
SERVER_LON=8.980018
SERVER_LOCATION_LABEL=SOC-ALPHA-01

# ── OPNsense API (optional, for real lockdown) ─
# OPNSENSE_HOST=https://192.168.1.1
# OPNSENSE_API_KEY=
# OPNSENSE_API_SECRET=
# OPNSENSE_REAL_MODE=false

# ── Geo-Block Rule Detection ────────────────────
# Comma-separated list of OPNsense firewall rule numbers that represent
# geo-blocking / blocklist policies (NOT active attacks).
# Find the rule number in OPNsense → Firewall → Log Files → raw log (first CSV field).
# Example: the log line "76,,,uuid,vlan010.2,match,block,in,..." has rule number 76.
GEO_BLOCK_RULES=76,77,64
# UUID of the OPNsense geo-block rule (field 3 in the filterlog CSV — the label UUID)
# Found from: 76,,,b0f57181e39d7cb375f45a5a1fc08909,vlan010.2,match,block,...
GEO_BLOCK_UUIDS=b0f57181e39d7cb375f45a5a1fc08909
